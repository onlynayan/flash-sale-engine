# Copy this file to .env and fill in your actual values
# NEVER commit the real .env file to git!

# Upstash Redis connection URL
# Get yours at: https://upstash.com (free tier available)
REDIS_URL=redis://default:YOUR_REDIS_PASSWORD@YOUR_HOST.upstash.io:6379

# Oracle Database connection URL (uses SQLAlchemy + oracledb driver in thin mode)
# Format: oracle+oracledb://username:password@host:port/?service_name=service
DATABASE_URL=oracle+oracledb://YOUR_USER:YOUR_PASSWORD@YOUR_HOST:1521/?service_name=YOUR_SERVICE_NAME
